<?xml version="1.0" encoding="utf-8" ?>
<configuration>
	
	<appSettings>
		<add key="LoadFactorMin" value="0.8"/>
		<add key="FlatlineEpsilon" value="0.01"/>
		<add key="FlatlineWindowSamples" value="4"/>
		<add key="SpikeDeltaMW" value="500"/>
	</appSettings>
	
	<system.serviceModel>

		<bindings>
			<netTcpBinding>
				<binding name="TcpStreamingBinding"
						 transferMode="Streamed"
						 maxReceivedMessageSize="10485760"
						 maxBufferSize="10485760">

					<readerQuotas
						maxDepth="32"
						maxStringContentLength="10485760"
						maxArrayLength="10485760"
						maxBytesPerRead="4096"
						maxNameTableCharCount="16384" />

				</binding>
			</netTcpBinding>
		</bindings>

		<services>

			<service name="EnergyConsumptionService.EnergyConsumptionServiceImpl">

				<host>
					<baseAddresses>
						<add baseAddress="net.tcp://localhost:4000/EnergyConsumptionService"/>
					</baseAddresses>
				</host>

				<endpoint
					address=""
					binding="netTcpBinding"
					bindingConfiguration="TcpStreamingBinding"
					contract="EnergyConsumptionService.Contracts.IEnergyConsumptionService" />

			</service>

		</services>

	</system.serviceModel>

</configuration>