<?xml version="1.0" encoding="utf-8" ?>
<configuration>
	<appSettings>
		<add key="CountryCode" value="DE"/>
		<add key="SelectedDate" value="2015-01-01"/>
		<add key="BatchSize" value="16"/>
		<add key="CsvPath" value="time_series_15min_singleindex.csv"/>
		<add key="SimulateTransferBreak" value="false"/>
		<add key="BreakAfterBatches" value="1"/>
	</appSettings>

	<system.serviceModel>
		<client>
			<endpoint
				name="EnergyConsumptionEndpoint"
				address="net.tcp://localhost:4000/EnergyConsumptionService"
				binding="netTcpBinding"
				bindingConfiguration="TcpStreamingBinding"
				contract="EnergyConsumptionService.Contracts.IEnergyConsumptionService" />
		</client>
		<bindings>
			<netTcpBinding>
				<binding name="TcpStreamingBinding"
						 transferMode="Streamed"
						 maxReceivedMessageSize="10485760"
						 maxBufferSize="10485760" />
			</netTcpBinding>
		</bindings>
	</system.serviceModel>
</configuration>